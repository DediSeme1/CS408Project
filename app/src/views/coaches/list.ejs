<div class="container py-4">


  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="mb-1">Coaches</h2>
      <p class="text-muted mb-0">Manage all gym coaches</p>
    </div>
    <a href="/coaches/add" class="btn btn-primary">
      <i class="bi bi-plus-lg me-1"></i> Add Coach
    </a>
  </div>

  <% if (coaches.length === 0) { %>
    <div class="alert alert-info">
      No coaches found. <a href="/coaches/add">Add your first coach.</a>
    </div>
  <% } else { %>
    <div class="card shadow-sm">
      <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Full Name</th>
              <th>Specialty</th>
              <th>Join Date</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% coaches.forEach(coach => { %>
              <tr>
                <td><strong><%= coach.first_name %> <%= coach.last_name %></strong></td>
                <td><span class="text-dark"><%= coach.speciality %></span></td>
                <td><%= coach.join_date %></td>
                <td class="text-end">
                  <div class="btn-group btn-group-sm">
                    <a href="/coaches/<%= coach.id %>" class="btn btn-sm btn-outline-primary me-1" title="View Details">
                      <i class="bi bi-eye"></i>
                    </a>
                
                    <form action="/coaches/<%= coach.id %>/delete" method="POST" class="d-inline"
                          onsubmit="return confirm('Delete <%= coach.first_name %> <%= coach.last_name %>? This cannot be undone.')">
                      <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete Coach">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <p class="text-muted mt-2 small"><%= coaches.length %> coach(es) total</p>
  <% } %>

</div>
