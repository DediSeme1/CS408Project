<div class="container py-4" style="max-width: 650px;">

  <a href="/coaches" class="text-decoration-none text-muted small">
    <i class="bi bi-arrow-left me-1"></i> Back to Coaches
  </a>


  <div class="d-flex justify-content-between align-items-start mt-3 mb-4">
    <div>
      <h2 class="mb-0"><%= coach.first_name %> <%= coach.last_name %></h2>
      <p class="text-muted mb-0">Coach Details</p>
    </div>
    <span class="badge bg-transparent text-dark fs-6"><%= coach.speciality %></span>
  </div>

  <% if (locals.errors && errors.length > 0) { %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% errors.forEach(e => { %>
          <li><%= e %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <% if (locals.editMode) { %>

  
    <div class="card shadow-sm mb-3">
      <div class="card-header bg-white fw-semibold">Edit Coach Information</div>
      <div class="card-body p-4">
        <form action="/coaches/<%= coach.id %>/edit" method="POST" novalidate>

          <div class="row mb-3">
            <div class="col">
              <label class="form-label fw-semibold">First Name <span class="text-danger">*</span></label>
              <input type="text" class="form-control" name="first_name" value="<%= coach.first_name %>" required>
            </div>
            <div class="col">
              <label class="form-label fw-semibold">Last Name <span class="text-danger">*</span></label>
              <input type="text" class="form-control" name="last_name" value="<%= coach.last_name %>" required>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
            <input type="email" class="form-control" name="email" value="<%= coach.email %>" required>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Phone Number <span class="text-danger">*</span></label>
            <input type="tel" class="form-control" name="phone_number" value="<%= coach.phone_number %>" required>
          </div>

          <div class="mb-4">
            <label class="form-label fw-semibold">Specialty <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="speciality" value="<%= coach.speciality %>" required>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">Save Changes</button>
            <a href="/coaches/<%= coach.id %>" class="btn btn-outline-secondary">Cancel</a>
          </div>

        </form>
      </div>
    </div>

  <% } else { %>

 
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-white fw-semibold">Coach Information</div>
      <div class="card-body">
        <table class="table table-borderless mb-0">
          <tbody>
            <tr>
              <td class="text-muted" style="width: 35%;">Full Name</td>
              <td><strong><%= coach.first_name %> <%= coach.last_name %></strong></td>
            </tr>
            <tr>
              <td class="text-muted">Specialty</td>
              <td><span class="text-dark"><%= coach.speciality %></span></td>
            </tr>
            <tr>
              <td class="text-muted">Email</td>
              <td>
                <i class="bi bi-envelope me-1 text-muted"></i>
                <a href="mailto:<%= coach.email %>" class="text-decoration-none"><%= coach.email %></a>
              </td>
            </tr>
            <tr>
              <td class="text-muted">Phone</td>
              <td>
                <i class="bi bi-telephone me-1 text-muted"></i>
                <%= coach.phone_number %>
              </td>
            </tr>
            <tr>
              <td class="text-muted">Join Date</td>
              <td>
                <i class="bi bi-calendar me-1 text-muted"></i>
                <%= coach.join_date %>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>


    <div class="d-flex justify-content-between">
      <a href="/coaches/<%= coach.id %>?edit=true" class="btn btn-success">
        <i class="bi bi-pencil me-1"></i> Edit Information
      </a>
      <form action="/coaches/<%= coach.id %>/delete" method="POST"
            onsubmit="return confirm('Permanently delete <%= coach.first_name %> <%= coach.last_name %>? This cannot be undone.')">
        <button type="submit" class="btn btn-outline-danger">
          <i class="bi bi-trash me-1"></i> Delete Coach
        </button>
      </form>
    </div>

  <% } %>

</div>