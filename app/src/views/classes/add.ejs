<div class="container py-4" style="max-width: 600px;">

  <a href="/classes" class="text-decoration-none text-muted small">
    <i class="bi bi-arrow-left me-1"></i> Back to Classes
  </a>

  <h2 class="mt-3 mb-1">Add New Class</h2>
  <p class="text-muted mb-4">Fill in the form to schedule a new class</p>

  <% if (errors.length > 0) { %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% errors.forEach(error => { %>
          <li><%= error %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <div class="card shadow-sm">
    <div class="card-body p-4">
      <form action="/classes/add" method="POST" novalidate>

        <div class="mb-3">
          <label for="class_name" class="form-label fw-semibold">Class Name <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="class_name" name="class_name"
                 placeholder="e.g. Morning Yoga" value="<%= formData.class_name || '' %>" required>
        </div>

        <div class="mb-3">
          <label for="coach" class="form-label fw-semibold">Coach <span class="text-danger">*</span></label>
          <select class="form-select" id="coach" name="coach" required>
            <option value="" disabled <%= !formData.coach ? 'selected' : '' %>>Select a coach</option>
            <% coaches.forEach(c => { %>
              <% const fullName = c.first_name + ' ' + c.last_name; %>
              <option value="<%= fullName %>" <%= formData.coach === fullName ? 'selected' : '' %>>
                <%= fullName %> — <%= c.specialty %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="mb-3">
          <label for="class_date" class="form-label fw-semibold">Date <span class="text-danger">*</span></label>
          <input type="date" class="form-control" id="class_date" name="class_date"
                 value="<%= formData.class_date || '' %>" required>
        </div>

        <div class="mb-3">
          <label for="class_time" class="form-label fw-semibold">Time <span class="text-danger">*</span></label>
          <input type="time" class="form-control" id="class_time" name="class_time"
                 value="<%= formData.class_time || '' %>" required>
        </div>

        <div class="mb-4">
          <label for="capacity" class="form-label fw-semibold">Maximum Capacity <span class="text-danger">*</span></label>
          <input type="number" class="form-control" id="capacity" name="capacity"
                 placeholder="e.g. 15" min="1" value="<%= formData.capacity || '' %>" required>
        </div>

        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary px-4">Add Class</button>
          <a href="/classes" class="btn btn-outline-secondary">Cancel</a>
        </div>

      </form>
    </div>
  </div>

</div>