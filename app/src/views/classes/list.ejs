<div class="container py-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="mb-1">Classes</h2>
      <p class="text-muted mb-0">Manage all gym classes</p>
    </div>
    <a href="/classes/add" class="btn btn-primary">
      <i class="bi bi-plus-lg me-1"></i> Add Class
    </a>
  </div>

  <% if (classes.length === 0) { %>
    <div class="alert alert-info">
      No classes found. <a href="/classes/add">Add your first class.</a>
    </div>
  <% } else { %>
    <div class="card shadow-sm">
      <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Class Name</th>
              <th>Coach</th>
              <th>Date</th>
              <th>Time</th>
              <th>Capacity</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% classes.forEach(cls => { %>
              <tr>
                <td><strong><%= cls.class_name %></strong></td>
                <td><%= cls.coach %></td>
                <td><%= cls.class_date %></td>
                <td><%= cls.class_time %></td>
                <td><%= cls.capacity %></td>
                <td class="text-end">
                  <a href="/classes/<%= cls.id %>" class="btn btn-sm btn-outline-primary me-1" title="View Details">
                    <i class="bi bi-eye"></i>
                  </a>
                  <form action="/classes/<%= cls.id %>/delete" method="POST" class="d-inline"
                        onsubmit="return confirm('Delete <%= cls.class_name %>? This cannot be undone.')">
                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete Class">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <p class="text-muted mt-2 small"><%= classes.length %> class(es) total</p>
  <% } %>

</div>
