<div class="container py-4" style="max-width: 650px;">

  <a href="/classes" class="text-decoration-none text-muted small">
    <i class="bi bi-arrow-left me-1"></i> Back to Classes
  </a>

  <div class="d-flex justify-content-between align-items-start mt-3 mb-4">
    <div>
      <h2 class="mb-0"><%= cls.class_name %></h2>
      <p class="text-muted mb-0">Class Details</p>
    </div>
    <span class="badge bg-primary fs-6"><%= cls.capacity %> max</span>
  </div>

  <% if (locals.errors && errors.length > 0) { %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% errors.forEach(e => { %>
          <li><%= e %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <% if (locals.editMode) { %>

   
    <div class="card shadow-sm mb-3">
      <div class="card-header bg-white fw-semibold">Edit Class Information</div>
      <div class="card-body p-4">
        <form action="/classes/<%= cls.id %>/edit" method="POST" novalidate>

          <div class="mb-3">
            <label class="form-label fw-semibold">Class Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="class_name" value="<%= cls.class_name %>" required>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Coach <span class="text-danger">*</span></label>
            <select class="form-select" name="coach" required>
              <% coaches.forEach(c => { %>
                <% const fullName = c.first_name + ' ' + c.last_name; %>
                <option value="<%= fullName %>" <%= cls.coach === fullName ? 'selected' : '' %>>
                  <%= fullName %> — <%= c.specialty %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Date <span class="text-danger">*</span></label>
            <input type="date" class="form-control" name="class_date" value="<%= cls.class_date %>" required>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Time <span class="text-danger">*</span></label>
            <input type="time" class="form-control" name="class_time" value="<%= cls.class_time %>" required>
          </div>

          <div class="mb-4">
            <label class="form-label fw-semibold">Maximum Capacity <span class="text-danger">*</span></label>
            <input type="number" class="form-control" name="capacity" min="1" value="<%= cls.capacity %>" required>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a href="/classes/<%= cls.id %>" class="btn btn-outline-secondary">Cancel</a>
          </div>

        </form>
      </div>
    </div>

  <% } else { %>

  
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-white fw-semibold">Class Information</div>
      <div class="card-body">
        <table class="table table-borderless mb-0">
          <tbody>
            <tr>
              <td class="text-muted" style="width: 35%;">Class Name</td>
              <td><strong><%= cls.class_name %></strong></td>
            </tr>
            <tr>
              <td class="text-muted">Coach</td>
              <td>
                <i class="bi bi-person me-1 text-muted"></i>
                <%= cls.coach %>
              </td>
            </tr>
            <tr>
              <td class="text-muted">Date</td>
              <td>
                <i class="bi bi-calendar me-1 text-muted"></i>
                <%= cls.class_date %>
              </td>
            </tr>
            <tr>
              <td class="text-muted">Time</td>
              <td>
                <i class="bi bi-clock me-1 text-muted"></i>
                <%= cls.class_time %>
              </td>
            </tr>
            <tr>
              <td class="text-muted">Capacity</td>
              <td>
                <i class="bi bi-people me-1 text-muted"></i>
                <%= cls.capacity %> participants max
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

   
    <div class="d-flex justify-content-between">
      <a href="/classes/<%= cls.id %>?edit=true" class="btn btn-primary">
        <i class="bi bi-pencil me-1"></i> Edit Information
      </a>
      <form action="/classes/<%= cls.id %>/delete" method="POST"
            onsubmit="return confirm('Permanently delete <%= cls.class_name %>? This cannot be undone.')">
        <button type="submit" class="btn btn-outline-danger">
          <i class="bi bi-trash me-1"></i> Delete Class
        </button>
      </form>
    </div>

  <% } %>

</div>