<div class="container py-4">

 
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="mb-1">Members</h2>
      <p class="text-muted mb-0">Manage all gym members</p>
    </div>
    <a href="/members/add" class="btn btn-primary">
      <i class="bi bi-plus-lg me-1"></i> Add Member
    </a>
  </div>

  
  <% if (members.length === 0) { %>
    <div class="alert alert-info">
      No members found. <a href="/members/add">Add your first member.</a>
    </div>
  <% } else { %>
    <div class="card shadow-sm">
      <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Member Name</th>
              <th>Status</th>
              <th>Join Date</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% members.forEach(member => { %>
              <tr>
                <td>
                  <strong><%= member.first_name %> <%= member.last_name %></strong>
                </td>
                <td>
                  <% if (member.status === 'Active') { %>
                    <span class="badge bg-success">Active</span>
                  <% } else { %>
                    <span class="badge bg-secondary">Inactive</span>
                  <% } %>
                </td>
                <td><%= member.join_date %></td>
                  <td class="text-end">
                    <div class="btn-group btn-group-sm">
                      <a href="/members/<%= member.id %>" class="btn btn-sm btn-outline-primary me-1" title="View Details">
                        <i class="bi bi-eye"></i>
                      </a>
                      <form action="/members/<%= member.id %>/status" method="POST" class="d-inline">
                        <input type="hidden" name="status" value="<%= member.status === 'Active' ? 'Inactive' : 'Active' %>">
                        <button type="submit" class="btn btn-sm btn-outline-warning me-1" title="Toggle Status">
                          <i class="bi bi-arrow-repeat"></i>
                        </button>
                      </form>
                      <form action="/members/<%= member.id %>/delete" method="POST" class="d-inline"
                            onsubmit="return confirm('Delete <%= member.first_name %> <%= member.last_name %>?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </div>
                  </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <p class="text-muted mt-2 small"><%= members.length %> member(s) total</p>
  <% } %>

</div>